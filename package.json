{
  "name": "react-shopping-cart",
  "description": "Desktop contractor measurement and invoice management app.",
  "author": "Codex",
  "main": "public/electron.js",
  "proxy": "http://localhost:5000",
  "homepage": ".",
  "version": "0.1.2",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.3.2",
    "@testing-library/user-event": "^7.1.2",
    "body-parser": "^1.19.0",
    "express": "^4.17.1",
    "jspdf": "2.5.1",
    "mongoose": "^5.9.14",
    "nodemon": "^2.0.4",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-modal": "^3.11.2",
    "react-redux": "^7.2.0",
    "react-reveal": "^1.2.2",
    "react-router-dom": "^5.2.0",
    "react-scripts": "3.4.1",
    "redux": "^4.0.5",
    "redux-thunk": "^2.3.0",
    "shortid": "^2.2.15",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.3"
  },
  "scripts": {
    "server": "nodemon server.js",
    "start": "react-scripts start",
    "start:web": "react-scripts start",
    "desktop:dev": "concurrently -k \"cross-env BROWSER=none PORT=3001 NODE_OPTIONS=--openssl-legacy-provider react-scripts start\" \"wait-on tcp:3001 && cross-env NODE_OPTIONS= electron .\"",
    "activation-tool:dev": "electron activation-tool/main.js",
    "build": "react-scripts build",
    "desktop:build": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts build && electron-builder",
    "activation-tool:build": "electron-builder --projectDir activation-tool",
    "license:generate": "node tools/generate-license.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": "12.4.0",
    "npm": "6.9.0"
  },
  "build": {
    "appId": "com.invoice.contractordesk",
    "productName": "إدارة ذرعات المقاولين",
    "files": [
      "build/**/*",
      "electron/**/*",
      "public/electron.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}

